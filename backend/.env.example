# --- Run the API (from backend/) ---
# source venv/bin/activate && uvicorn app.main:app --reload --port 8001 --host 0.0.0.0
# If http://localhost:8001/api/health just spins, use http://127.0.0.1:8001/api/health (IPv4).

JWT_SECRET=your-secret-key-change-in-production
SUPER_ADMIN_EMAIL=admin@example.com

# --- PRODUCTION Firestore ---
# Path to your Firebase service account JSON (required for production).
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Optional: set if your JSON doesn't include project_id (default: membercore)
# GCLOUD_PROJECT=your-firebase-project-id

# --- EMULATOR (leave commented out for production) ---
# Uncomment only when using firebase emulators:start --only firestore
# FIRESTORE_EMULATOR_HOST=localhost:8080

# --- Stripe (event ticketing). Required for "Buy Ticket" to work. See docs/PAYMENTS.md ---
# STRIPE_SECRET_KEY=sk_test_xxx
# FRONTEND_URL=http://localhost:5173
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Stripe Pro subscriptions ($97/mo, $970/yr). Set these for org upgrade flow. ---
# Create two Prices in Stripe Dashboard: one $97/month recurring, one $970/year recurring.
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_ANNUAL=price_xxx
# Optional: redirect after checkout (e.g. mobile deep link or hosted thank-you page).
# BILLING_SUCCESS_URL=membercore://billing/success
# BILLING_CANCEL_URL=membercore://billing/cancel
